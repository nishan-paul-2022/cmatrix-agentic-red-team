# Development Dockerfile for Next.js Frontend
FROM node:20-alpine

# Install node_modules in a SEPARATE directory (/app_modules) that is
# completely outside the /app volume mount. This means:
#   - Docker's packages never clash with your laptop's node_modules
#   - You will never see EACCES permission errors again
#   - npm install on your laptop works independently, any time
WORKDIR /app_modules

# Copy package files into the isolated modules directory
COPY --chown=node:node package.json ./

# Install all dependencies into /app_modules/node_modules
RUN npm install --legacy-peer-deps

# Switch the working directory to the actual app (which will be volume-mounted)
WORKDIR /app

# Ensure /app is owned by the non-root node user
RUN chown -R node:node /app

# Copy entrypoint script as root, then lock down permissions
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Run as the non-root 'node' user for full security (Automated Non-Root Execution)
USER node

# Expose the dev server port
EXPOSE 3000

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
