{
  "name": "cmatrix-agentic-red-team",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1"
  },
  "lint-staged": {
    "app-frontend/**/*.{ts,tsx}": [
      "cd app-frontend && npm run lint:fix",
      "cd app-frontend && npm run format"
    ],
    "app-frontend/**/*.{css,json,mjs}": [
      "cd app-frontend && npm run format"
    ],
    "app-backend/**/*.py": [
      "app-backend/venv/bin/ruff check --fix",
      "app-backend/venv/bin/ruff format"
    ]
  }
}
