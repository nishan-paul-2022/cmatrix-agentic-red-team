# Application Configuration
APP_NAME="CMatrix"
APP_VERSION="0.0.1"
DEBUG=false
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Database
POSTGRES_USER=cmatrix
POSTGRES_PASSWORD=cmatrix
POSTGRES_DB=cmatrix
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Security & JWT
SECRET_KEY=your-secret-key-change-this-in-production-make-it-very-long-and-random-abc123xyz789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis (Celery)
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://localhost:${REDIS_PORT}/1

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}
QDRANT_COLLECTION_NAME=cmatrix_memory

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Command Execution
COMMAND_TIMEOUT=30
ENABLE_SUDO=false

# Logging
LOG_LEVEL=INFO
